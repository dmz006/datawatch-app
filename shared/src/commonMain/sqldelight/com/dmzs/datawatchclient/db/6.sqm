-- Migration 6 → 7 (Signal device-linking: linked state per profile).
--
-- BL21 (v0.64.0) adds Signal QR-code pairing from Settings → Comms. The
-- boolean persists so the Channels card shows "Linked" without a round-trip
-- on every open. NULL-safe: existing rows get 0 (false) on upgrade;
-- touchLastSeen / re-pair updates it via upsert.

ALTER TABLE server_profile ADD COLUMN signal_linked INTEGER NOT NULL DEFAULT 0;
