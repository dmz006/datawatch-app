<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome variant for Android 13+ themed launcher icons. Must be single-color
    opaque silhouette; Android tints based on the user's dynamic theme.
    Simplified version of the foreground that reads legibly when tinted to a
    single color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="?attr/colorControlNormal">

    <!-- Signal arcs -->
    <path android:pathData="M 29,27 A 25,25 0 0,1 79,27"
          android:strokeColor="#000000"
          android:strokeWidth="1.8"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>
    <path android:pathData="M 35,30 A 19,19 0 0,1 73,30"
          android:strokeColor="#000000"
          android:strokeWidth="1.8"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>
    <path android:pathData="M 41,33 A 13,13 0 0,1 67,33"
          android:strokeColor="#000000"
          android:strokeWidth="2.2"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>

    <!-- Phone body outline -->
    <path android:pathData="M 36,38
                            h 36
                            a 8,8 0 0 1 8,8
                            v 42
                            a 8,8 0 0 1 -8,8
                            h -36
                            a 8,8 0 0 1 -8,-8
                            v -42
                            a 8,8 0 0 1 8,-8
                            z"
          android:fillColor="#000000"/>

    <!-- Screen (carved out) -->
    <path android:pathData="M 33,46
                            h 42
                            a 3,3 0 0 1 3,3
                            v 36
                            a 3,3 0 0 1 -3,3
                            h -42
                            a 3,3 0 0 1 -3,-3
                            v -36
                            a 3,3 0 0 1 3,-3
                            z
                            M 36,62
                            a 18,10 0 1 0 36,0
                            a 18,10 0 1 0 -36,0 z"
          android:fillColor="#00000000"
          android:fillType="evenOdd"/>

    <!-- Eye (silhouette ring) -->
    <path android:pathData="M 36,62
                            a 18,10 0 1 0 36,0
                            a 18,10 0 1 0 -36,0 z
                            M 46,62
                            a 8,8 0 1 0 16,0
                            a 8,8 0 1 0 -16,0 z"
          android:fillColor="#000000"
          android:fillType="evenOdd"/>

    <!-- Pupil -->
    <path android:pathData="M 50.5,62 a 3.5,3.5 0 1 0 7,0 a 3.5,3.5 0 1 0 -7,0 z"
          android:fillColor="#000000"/>
</vector>
