<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-feature android:name="android.hardware.type.watch"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.VIBRATE"/>

    <application
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@android:style/Theme.DeviceDefault">

        <uses-library android:name="com.google.android.wearable" android:required="true"/>

        <meta-data android:name="com.google.android.wearable.standalone" android:value="false"/>

        <!--
            Explicit icon on the activity too, because the Galaxy
            Watch launcher on One UI Watch reads activity-level icon
            when drawing the app-drawer grid rather than falling back
            to the application-level one. Without this, the Wear APK
            installs but the app never appears in the drawer (W1).
        -->
        <activity
            android:name=".WearMainActivity"
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher_round"
            android:label="@string/app_name"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- Wear Tile — Sessions glance (running / waiting / total). -->
        <service
            android:name=".tile.SessionsTileService"
            android:exported="true"
            android:label="@string/tile_sessions_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER"/>
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@android:drawable/ic_menu_info_details"/>
        </service>

        <!-- Wear Tile — Monitor glance (CPU / memory / sessions). -->
        <service
            android:name=".tile.MonitorTileService"
            android:exported="true"
            android:label="@string/tile_monitor_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER"/>
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@android:drawable/ic_menu_info_details"/>
        </service>

        <!-- Wear Tile — Waiting sessions glance (W-8). -->
        <service
            android:name=".tile.WaitingTileService"
            android:exported="true"
            android:label="@string/tile_waiting_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER"/>
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@android:drawable/ic_menu_info_details"/>
        </service>

        <!-- Complications — W-2, W-9, W-10 -->
        <service
            android:name=".complication.WaitingComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="datawatch Waiting"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <service
            android:name=".complication.SessionsComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="datawatch Sessions"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <service
            android:name=".complication.CpuComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="datawatch CPU"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <service
            android:name=".complication.MemoryComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="datawatch Memory"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <service
            android:name=".complication.ServerSwitchComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="datawatch Server"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <!-- W-#114 — Alerts tile (total / needs-input / error breakdown). -->
        <service
            android:name=".tile.AlertsTileService"
            android:exported="true"
            android:label="@string/tile_alerts_label"
            android:permission="com.google.android.wearable.permission.BIND_TILE_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.tiles.action.BIND_TILE_PROVIDER"/>
            </intent-filter>
            <meta-data
                android:name="androidx.wear.tiles.PREVIEW"
                android:resource="@android:drawable/ic_menu_info_details"/>
        </service>

        <!-- W-#108 — Automata count / council count complication. -->
        <service
            android:name=".complication.AutomataComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/complication_automata_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <!-- W-#114 — Active alert count complication. -->
        <service
            android:name=".complication.AlertsComplicationService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/complication_alerts_label"
            android:permission="com.google.android.wearable.permission.BIND_COMPLICATION_PROVIDER">
            <intent-filter>
                <action android:name="androidx.wear.watchface.complications.datasource.ACTION_COMPLICATION_UPDATE_REQUEST"/>
            </intent-filter>
            <meta-data
                android:name="android.support.wearable.complications.SUPPORTED_TYPES"
                android:value="SHORT_TEXT"/>
            <meta-data
                android:name="android.support.wearable.complications.UPDATE_PERIOD_SECONDS"
                android:value="300"/>
        </service>

        <!-- BroadcastReceiver for server-switch complication tap (W-10). -->
        <receiver
            android:name=".complication.ServerSwitchReceiver"
            android:exported="false"/>

        <!-- WearableListenerService for session alerts (BL27, W-#107, BL303-W3). -->
        <service
            android:name=".WearAlertListenerService"
            android:exported="true"
            android:permission="com.google.android.gms.wearable.BIND_LISTENER">
            <intent-filter>
                <action android:name="com.google.android.gms.wearable.MESSAGE_RECEIVED"/>
                <data android:scheme="wear" android:pathPrefix="/datawatch/alert"/>
                <data android:scheme="wear" android:pathPrefix="/datawatch/council"/>
                <data android:scheme="wear" android:pathPrefix="/datawatch/error-alert"/>
                <data android:scheme="wear" android:pathPrefix="/datawatch/guardrailBlock"/>
            </intent-filter>
        </service>

        <!-- BL303-W3: guardrail approve confirmation screen. -->
        <activity
            android:name=".WearApproveScreen"
            android:exported="false"
            android:theme="@android:style/Theme.DeviceDefault"
            android:taskAffinity=".approve"/>

        <!-- BL303-W3: dismiss BroadcastReceiver for guardrail block notification. -->
        <receiver
            android:name=".GuardrailDismissReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.dmzs.datawatchclient.wear.ACTION_GUARDRAIL_DISMISS"/>
            </intent-filter>
        </receiver>
    </application>
</manifest>
