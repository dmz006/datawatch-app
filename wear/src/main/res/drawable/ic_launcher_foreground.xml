<?xml version="1.0" encoding="utf-8"?>
<!--
    Wear launcher icon foreground — high-contrast eye.
    Problem: dark sclera on dark background = invisible.
    Fix: white/light sclera fill so the eye POPS against the dark background.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sparse matrix rain corners — subtle, 2×2 px dots -->
    <path android:pathData="M 18,15 h 2 v 2 h -2 z M 18,21 h 2 v 2 h -2 z M 18,27 h 2 v 2 h -2 z
                            M 26,12 h 2 v 2 h -2 z M 26,18 h 2 v 2 h -2 z M 26,24 h 2 v 2 h -2 z M 26,30 h 2 v 2 h -2 z
                            M 82,12 h 2 v 2 h -2 z M 82,18 h 2 v 2 h -2 z M 82,24 h 2 v 2 h -2 z M 82,30 h 2 v 2 h -2 z
                            M 90,15 h 2 v 2 h -2 z M 90,21 h 2 v 2 h -2 z M 90,27 h 2 v 2 h -2 z
                            M 18,81 h 2 v 2 h -2 z M 18,87 h 2 v 2 h -2 z M 18,93 h 2 v 2 h -2 z
                            M 26,78 h 2 v 2 h -2 z M 26,84 h 2 v 2 h -2 z M 26,90 h 2 v 2 h -2 z
                            M 82,78 h 2 v 2 h -2 z M 82,84 h 2 v 2 h -2 z M 82,90 h 2 v 2 h -2 z
                            M 90,81 h 2 v 2 h -2 z M 90,87 h 2 v 2 h -2 z M 90,93 h 2 v 2 h -2 z"
        android:fillColor="#A855F7"
        android:fillAlpha="0.60"/>

    <!-- Sclera outer glow (soft purple halo) -->
    <path android:pathData="M 54,54 m -40,0 a 40,26 0 1 0 80,0 a 40,26 0 1 0 -80,0 z"
        android:fillColor="#9333EA"
        android:fillAlpha="0.25"/>

    <!-- Sclera — WHITE fill so the eye is clearly visible on dark background -->
    <path android:pathData="M 54,54 m -36,0 a 36,22 0 1 0 72,0 a 36,22 0 1 0 -72,0 z"
        android:fillColor="#F0E8FF"/>

    <!-- Sclera border — bright violet, bold -->
    <path android:pathData="M 54,54 m -36,0 a 36,22 0 1 0 72,0 a 36,22 0 1 0 -72,0 z"
        android:strokeColor="#7C3AED"
        android:strokeWidth="2.5"
        android:fillColor="#00000000"/>

    <!-- Iris — deep violet, radius 18, fills sclera -->
    <path android:pathData="M 54,54 m -18,0 a 18,18 0 1 0 36,0 a 18,18 0 1 0 -36,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="54" android:centerY="54"
                android:gradientRadius="19"
                android:startColor="#C084FC"
                android:centerColor="#7C3AED"
                android:endColor="#3B0764"/>
        </aapt:attr>
    </path>

    <!-- Iris inner ring -->
    <path android:pathData="M 54,54 m -14,0 a 14,14 0 1 0 28,0 a 14,14 0 1 0 -28,0 z"
        android:fillColor="#A855F7"
        android:fillAlpha="0.55"/>

    <!-- Iris ring detail stroke -->
    <path android:pathData="M 54,54 m -17,0 a 17,17 0 1 0 34,0 a 17,17 0 1 0 -34,0 z"
        android:strokeColor="#D8B4FE"
        android:strokeWidth="0.8"
        android:strokeAlpha="0.6"
        android:fillColor="#00000000"/>

    <!-- Pupil — solid black -->
    <path android:pathData="M 54,54 m -7,0 a 7,7 0 1 0 14,0 a 7,7 0 1 0 -14,0 z"
        android:fillColor="#030108"/>

    <!-- Pupil ring -->
    <path android:pathData="M 54,54 m -8,0 a 8,8 0 1 0 16,0 a 8,8 0 1 0 -16,0 z"
        android:strokeColor="#9333EA"
        android:strokeWidth="0.7"
        android:strokeAlpha="0.55"
        android:fillColor="#00000000"/>

    <!-- Crosshair — bright pink, clearly visible through sclera -->
    <path android:pathData="M 54,43 v 5.5 M 54,59.5 v 5.5 M 42,54 h 5.5 M 60.5,54 h 5.5"
        android:strokeColor="#E879F9"
        android:strokeWidth="2.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Center highlight -->
    <path android:pathData="M 54,54 m -1.3,0 a 1.3,1.3 0 1 0 2.6,0 a 1.3,1.3 0 1 0 -2.6,0 z"
        android:fillColor="#F5F0FF"/>

    <!-- Lens highlight (upper-left of iris) -->
    <path android:pathData="M 47,49 m -3.5,0 a 3.5,1.6 0 1 0 7,0 a 3.5,1.6 0 1 0 -7,0 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.50"/>

</vector>
