<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome variant for Android 13+ themed launcher icons. Single-color
    silhouette tinted by system theme. Reduced to the eye glyph + a few
    matrix-rain dots so the icon still reads as 'datawatch' when stripped
    of color.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="?attr/colorControlNormal">

    <!-- Sparse matrix dots (texture hint) -->
    <path android:pathData="M 22,16 h 1 v 1 h -1 z M 22,24 h 1 v 1 h -1 z M 22,80 h 1 v 1 h -1 z M 22,88 h 1 v 1 h -1 z M 32,18 h 1 v 1 h -1 z M 32,84 h 1 v 1 h -1 z M 42,16 h 1 v 1 h -1 z M 42,80 h 1 v 1 h -1 z M 65,16 h 1 v 1 h -1 z M 65,84 h 1 v 1 h -1 z M 75,16 h 1 v 1 h -1 z M 75,84 h 1 v 1 h -1 z M 85,18 h 1 v 1 h -1 z M 85,80 h 1 v 1 h -1 z"
        android:fillColor="#000000"
        android:fillAlpha="0.45"/>

    <!-- Eye sclera -->
    <path android:pathData="M 54,54 m -22,0 a 22,14 0 1 0 44,0 a 22,14 0 1 0 -44,0 z"
        android:fillColor="#000000"/>

    <!-- Iris (lighter inside via white-with-alpha) -->
    <path android:pathData="M 54,54 m -12,0 a 12,12 0 1 0 24,0 a 12,12 0 1 0 -24,0 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.50"/>

    <!-- Pupil -->
    <path android:pathData="M 54,54 m -5,0 a 5,5 0 1 0 10,0 a 5,5 0 1 0 -10,0 z"
        android:fillColor="#000000"/>

    <!-- Crosshair -->
    <path android:pathData="M 54,49 v 2 M 54,57 v 2 M 49,54 h 2 M 57,54 h 2"
        android:strokeColor="#000000"
        android:strokeWidth="0.7"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>
</vector>
