<?xml version="1.0" encoding="utf-8"?>
<!--
    Launcher icon foreground — eye fits within the 66dp safe zone
    (inner 66dp of the 108dp adaptive icon canvas = positions 21–87).
    Sclera: ±33×21 centered at (54,54) → left=21, right=87.
    Iris r=18, pupil r=7, crosshair stays within safe zone.
    Shrunk from ±40×26 (B68 — eye overflowed AAOS icon boundary).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Matrix rain — sparse columns inside the safe zone -->
    <path android:pathData="M 24,24 h 1 v 1 h -1 z M 24,28 h 1 v 1 h -1 z M 24,32 h 1 v 1 h -1 z
                            M 24,74 h 1 v 1 h -1 z M 24,78 h 1 v 1 h -1 z M 24,82 h 1 v 1 h -1 z
                            M 33,22 h 1 v 1 h -1 z M 33,26 h 1 v 1 h -1 z M 33,30 h 1 v 1 h -1 z
                            M 33,76 h 1 v 1 h -1 z M 33,80 h 1 v 1 h -1 z M 33,84 h 1 v 1 h -1 z
                            M 74,24 h 1 v 1 h -1 z M 74,28 h 1 v 1 h -1 z M 74,32 h 1 v 1 h -1 z
                            M 74,74 h 1 v 1 h -1 z M 74,78 h 1 v 1 h -1 z M 74,82 h 1 v 1 h -1 z
                            M 83,22 h 1 v 1 h -1 z M 83,26 h 1 v 1 h -1 z M 83,30 h 1 v 1 h -1 z
                            M 83,76 h 1 v 1 h -1 z M 83,80 h 1 v 1 h -1 z M 83,84 h 1 v 1 h -1 z"
        android:fillColor="#A855F7"
        android:fillAlpha="0.45"/>

    <!-- Sclera: wide almond — fits within 66dp safe zone -->
    <path android:pathData="M 54,54 m -33,0 a 33,21 0 1 0 66,0 a 33,21 0 1 0 -66,0 z"
        android:fillColor="#080518"
        android:strokeColor="#7C3AED"
        android:strokeWidth="0.8"/>

    <!-- Iris with radial gradient -->
    <path android:pathData="M 54,54 m -18,0 a 18,18 0 1 0 36,0 a 18,18 0 1 0 -36,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                android:centerX="47" android:centerY="47"
                android:gradientRadius="20"
                android:startColor="#A855F7"
                android:centerColor="#7C3AED"
                android:endColor="#3B0764"/>
        </aapt:attr>
    </path>

    <!-- Iris ring detail -->
    <path android:pathData="M 54,54 m -17,0 a 17,17 0 1 0 34,0 a 17,17 0 1 0 -34,0 z"
        android:strokeColor="#A855F7"
        android:strokeWidth="0.5"
        android:strokeAlpha="0.5"
        android:fillColor="#00000000"/>
    <path android:pathData="M 54,54 m -13,0 a 13,13 0 1 0 26,0 a 13,13 0 1 0 -26,0 z"
        android:strokeColor="#C084FC"
        android:strokeWidth="0.4"
        android:strokeAlpha="0.4"
        android:fillColor="#00000000"/>

    <!-- Pupil -->
    <path android:pathData="M 54,54 m -7,0 a 7,7 0 1 0 14,0 a 7,7 0 1 0 -14,0 z"
        android:fillColor="#04020E"/>
    <path android:pathData="M 54,54 m -6.5,0 a 6.5,6.5 0 1 0 13,0 a 6.5,6.5 0 1 0 -13,0 z"
        android:strokeColor="#7C3AED"
        android:strokeWidth="0.4"
        android:strokeAlpha="0.5"
        android:fillColor="#00000000"/>

    <!-- Crosshair — stays within safe zone -->
    <path android:pathData="M 54,28 v 5 M 54,75 v 5 M 27,54 h 5 M 76,54 h 5"
        android:strokeColor="#E879F9"
        android:strokeWidth="1.0"
        android:strokeLineCap="round"
        android:fillColor="#00000000"/>

    <!-- Center highlight -->
    <path android:pathData="M 54,54 m -1.5,0 a 1.5,1.5 0 1 0 3,0 a 1.5,1.5 0 1 0 -3,0 z"
        android:fillColor="#F0ABFC"/>

    <!-- Lens highlight: upper-left of iris -->
    <path android:pathData="M 46,46 m -2.8,-1.2 a 2.8,1.2 0 1 0 5.6,0 a 2.8,1.2 0 1 0 -5.6,0 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.22"/>
</vector>
