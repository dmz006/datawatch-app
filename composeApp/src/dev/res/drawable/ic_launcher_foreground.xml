<?xml version="1.0" encoding="utf-8"?>
<!--
    Dev-flavor foreground override (ADR-0031 / ADR-0041): same silhouette as public,
    plus a "DEV" chip in the lower right so the two side-by-side installs are visually
    distinguishable at a glance. System-level tint (monochrome) renders a simplified
    variant via ic_launcher_monochrome_dev.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Signal arcs -->
    <path android:pathData="M 29,27 A 25,25 0 0,1 79,27"
          android:strokeColor="#7C3AED" android:strokeWidth="1.6"
          android:strokeLineCap="round" android:fillColor="#00000000"
          android:strokeAlpha="0.45"/>
    <path android:pathData="M 35,30 A 19,19 0 0,1 73,30"
          android:strokeColor="#A855F7" android:strokeWidth="1.8"
          android:strokeLineCap="round" android:fillColor="#00000000"
          android:strokeAlpha="0.70"/>
    <path android:pathData="M 41,33 A 13,13 0 0,1 67,33"
          android:strokeColor="#A855F7" android:strokeWidth="2.2"
          android:strokeLineCap="round" android:fillColor="#00000000"
          android:strokeAlpha="0.95"/>

    <!-- Phone body -->
    <path android:pathData="M 36,38 h 36 a 8,8 0 0 1 8,8 v 42 a 8,8 0 0 1 -8,8 h -36 a 8,8 0 0 1 -8,-8 v -42 a 8,8 0 0 1 8,-8 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="linear"
                      android:startX="54" android:startY="38"
                      android:endX="54" android:endY="96"
                      android:startColor="#1E1235" android:endColor="#0D0720"/>
        </aapt:attr>
    </path>
    <path android:pathData="M 36,38 h 36 a 8,8 0 0 1 8,8 v 42 a 8,8 0 0 1 -8,8 h -36 a 8,8 0 0 1 -8,-8 v -42 a 8,8 0 0 1 8,-8 z"
          android:strokeColor="#7C3AED" android:strokeWidth="0.9"
          android:fillColor="#00000000"/>

    <!-- Speaker, screen, eye, pupil, home indicator — same as public -->
    <path android:pathData="M 49,42 h 10 v 1.6 h -10 z" android:fillColor="#2D1B4E"/>
    <path android:pathData="M 33,46 h 42 a 3,3 0 0 1 3,3 v 36 a 3,3 0 0 1 -3,3 h -42 a 3,3 0 0 1 -3,-3 v -36 a 3,3 0 0 1 3,-3 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                      android:centerX="54" android:centerY="67"
                      android:gradientRadius="24"
                      android:startColor="#2A1550" android:endColor="#0A0318"/>
        </aapt:attr>
    </path>
    <path android:pathData="M 36,62 a 18,10 0 1 0 36,0 a 18,10 0 1 0 -36,0 z"
          android:fillColor="#080518"
          android:strokeColor="#7C3AED" android:strokeWidth="0.5"/>
    <path android:pathData="M 46,62 a 8,8 0 1 0 16,0 a 8,8 0 1 0 -16,0 z">
        <aapt:attr name="android:fillColor">
            <gradient android:type="radial"
                      android:centerX="53" android:centerY="60"
                      android:gradientRadius="9"
                      android:startColor="#A855F7" android:endColor="#3B0764"/>
        </aapt:attr>
    </path>
    <path android:pathData="M 50.5,62 a 3.5,3.5 0 1 0 7,0 a 3.5,3.5 0 1 0 -7,0 z"
          android:fillColor="#04020E"/>
    <path android:pathData="M 54,59.5 v 1.2 M 54,63.3 v 1.2 M 51.5,62 h 1.2 M 55.3,62 h 1.2"
          android:strokeColor="#E879F9" android:strokeWidth="0.55"
          android:strokeLineCap="round" android:fillColor="#00000000"/>
    <path android:pathData="M 47,90 h 14 v 1.8 h -14 z"
          android:fillColor="#4C1D95" android:fillAlpha="0.8"/>

    <!-- "DEV" badge chip — amber/warning tone for at-a-glance distinction -->
    <path android:pathData="M 59,82 h 18 a 2,2 0 0 1 2,2 v 6 a 2,2 0 0 1 -2,2 h -18 a 2,2 0 0 1 -2,-2 v -6 a 2,2 0 0 1 2,-2 z"
          android:fillColor="#F59E0B"/>
    <path android:pathData="M 60,85 h 1.5 v 1 h -1.5 z M 60,87 h 1.5 v 1 h -1.5 z M 60,89 h 1.5 v 1 h -1.5 z
                            M 62,85 h 1.5 M 62,89 h 1.5
                            M 64,85 h 1.5 v 5 h -1.5 z M 64,87 h 1 v 1 h -1 z
                            M 66,85 h 0.6 l 0.7,4 l 0.7,-4 h 0.6 l -0.9,5 h -0.8 z"
          android:fillColor="#0F1117"/>
</vector>
