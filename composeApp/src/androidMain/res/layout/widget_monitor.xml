<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_monitor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_stat_dw"
            android:tint="#A855F7"
            android:contentDescription="@null"/>
        <TextView
            android:id="@+id/widget_monitor_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor"
            android:textColor="#A855F7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"/>
        <TextView
            android:id="@+id/widget_monitor_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text=""/>
    </LinearLayout>

    <!-- CPU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="CPU"/>
        <TextView
            android:id="@+id/widget_monitor_cpu_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_cpu_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="2dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#A855F7"
        android:progressBackgroundTint="#3B1D6B"/>

    <!-- Memory -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="8dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="Memory"/>
        <TextView
            android:id="@+id/widget_monitor_mem_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_mem_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="2dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#A855F7"
        android:progressBackgroundTint="#3B1D6B"/>

    <!-- Sessions -->
    <TextView
        android:id="@+id/widget_monitor_sessions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="#888"
        android:textSize="11sp"
        android:layout_marginTop="10dp"
        android:text="—"/>

</LinearLayout>
