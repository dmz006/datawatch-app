<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome variant for Android 13+ themed launcher icons. Single-color
    silhouette; system tints to match the user's wallpaper. Reduced to the
    essential shapes: moon horizon + tablet + eye + Earth.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="?attr/colorControlNormal">

    <!-- Earth — small disc, top-center (matches foreground v2) -->
    <path android:pathData="M 58.4,16 m -7,0 a 7,7 0 1 0 14,0 a 7,7 0 1 0 -14,0 z"
        android:fillColor="#000000"/>

    <!-- Moon surface — horizon raised to y=30 -->
    <path android:pathData="M 0,30 Q 54,26 108,32 L 108,108 L 0,108 Z"
        android:fillColor="#000000"/>

    <!-- Crater silhouettes -->
    <path android:pathData="M 12,98 m -9,0 a 9,2.8 0 1 0 18,0 a 9,2.8 0 1 0 -18,0 z M 96,99 m -10,0 a 10,3 0 1 0 20,0 a 10,3 0 1 0 -20,0 z M 22,40 m -5,0 a 5,1.5 0 1 0 10,0 a 5,1.5 0 1 0 -10,0 z M 86,40 m -5,0 a 5,1.5 0 1 0 10,0 a 5,1.5 0 1 0 -10,0 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.35"/>

    <!-- Tablet body — centered, large -->
    <path android:pathData="M 24,40 h 60 a 3,3 0 0 1 3,3 v 42 a 3,3 0 0 1 -3,3 h -60 a 3,3 0 0 1 -3,-3 v -42 a 3,3 0 0 1 3,-3 z"
        android:fillColor="#000000"/>

    <!-- Tablet screen carved out -->
    <path android:pathData="M 28,44 h 52 a 2,2 0 0 1 2,2 v 36 a 2,2 0 0 1 -2,2 h -52 a 2,2 0 0 1 -2,-2 v -36 a 2,2 0 0 1 2,-2 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.25"/>

    <!-- Eye on tablet — significantly larger to match foreground v2 -->
    <path android:pathData="M 54,64 m -18,0 a 18,11 0 1 0 36,0 a 18,11 0 1 0 -36,0 z"
        android:fillColor="#000000"/>
    <path android:pathData="M 54,64 m -9,0 a 9,9 0 1 0 18,0 a 9,9 0 1 0 -18,0 z"
        android:fillColor="#FFFFFF"
        android:fillAlpha="0.5"/>
    <path android:pathData="M 54,64 m -4,0 a 4,4 0 1 0 8,0 a 4,4 0 1 0 -8,0 z"
        android:fillColor="#000000"/>
</vector>
