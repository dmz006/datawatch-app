<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_monitor_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg"
    android:padding="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_stat_dw"
            android:tint="#A855F7"
            android:contentDescription="@null"/>
        <TextView
            android:id="@+id/widget_monitor_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Monitor"
            android:textColor="#A855F7"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="6dp"/>
        <TextView
            android:id="@+id/widget_monitor_profile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888"
            android:textSize="11sp"
            android:layout_marginStart="8dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text=""/>
    </LinearLayout>

    <!-- CPU -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="CPU"/>
        <TextView
            android:id="@+id/widget_monitor_cpu_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_cpu_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#A855F7"
        android:progressBackgroundTint="#3B1D6B"/>

    <!-- Memory -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="Memory"/>
        <TextView
            android:id="@+id/widget_monitor_mem_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_mem_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#A855F7"
        android:progressBackgroundTint="#3B1D6B"/>

    <!-- Disk -->
    <LinearLayout
        android:id="@+id/widget_monitor_disk_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="Disk"/>
        <TextView
            android:id="@+id/widget_monitor_disk_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_disk_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#A855F7"
        android:progressBackgroundTint="#3B1D6B"/>

    <!-- Swap (conditional — only hosts with swap configured) -->
    <LinearLayout
        android:id="@+id/widget_monitor_swap_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="Swap"/>
        <TextView
            android:id="@+id/widget_monitor_swap_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_swap_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#F59E0B"
        android:progressBackgroundTint="#3B1D6B"
        android:visibility="gone"/>

    <!-- GPU / VRAM (only shown when server reports a GPU) -->
    <LinearLayout
        android:id="@+id/widget_monitor_gpu_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp"
        android:visibility="gone">
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="GPU"/>
        <TextView
            android:id="@+id/widget_monitor_gpu_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text="—"/>
    </LinearLayout>
    <ProgressBar
        android:id="@+id/widget_monitor_gpu_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:layout_marginTop="1dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#10B981"
        android:progressBackgroundTint="#1F3A2E"
        android:visibility="gone"/>

    <!-- Network (↓ rx  ↑ tx) — cumulative bytes from /api/stats -->
    <LinearLayout
        android:id="@+id/widget_monitor_net_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="6dp">
        <TextView
            android:id="@+id/widget_monitor_net_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:text="Net"/>
        <TextView
            android:id="@+id/widget_monitor_net_rx"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#10B981"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:gravity="end"
            android:singleLine="true"
            android:text=""/>
        <TextView
            android:id="@+id/widget_monitor_net_tx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#A855F7"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginStart="6dp"
            android:singleLine="true"
            android:text=""/>
    </LinearLayout>

    <!-- Daemon footer — daemon RSS + goroutines -->
    <LinearLayout
        android:id="@+id/widget_monitor_daemon_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:textSize="10sp"
            android:text="Daemon"/>
        <TextView
            android:id="@+id/widget_monitor_daemon_value"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#888"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:gravity="end"
            android:singleLine="true"
            android:text=""/>
    </LinearLayout>

    <!-- Sessions + Uptime footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">
        <TextView
            android:id="@+id/widget_monitor_sessions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#CCC"
            android:textSize="11sp"
            android:singleLine="true"
            android:ellipsize="end"
            android:text="—"/>
        <TextView
            android:id="@+id/widget_monitor_uptime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:text=""/>
    </LinearLayout>

</LinearLayout>
