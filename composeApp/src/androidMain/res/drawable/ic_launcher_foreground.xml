<?xml version="1.0" encoding="utf-8"?>
<!--
    Adaptive icon foreground — Concept B (phone silhouette + mini eye + signal arcs).
    Android 108dp canvas; critical content sits inside the inner 66dp safe-zone
    circle so no mask shape ever clips it.

    Coordinates: all shapes authored in the 108-unit viewport. The master SVG
    (assets/icon-master-512.svg) is the reference; this is the device-compatible
    VectorDrawable port — no SVG filters, gradients via aapt:attr.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Signal arcs — concentric, three levels, top-fading purple. -->
    <!-- outer (faintest) -->
    <path android:pathData="M 29,27 A 25,25 0 0,1 79,27"
          android:strokeColor="#7C3AED"
          android:strokeWidth="1.6"
          android:strokeLineCap="round"
          android:fillColor="#00000000"
          android:strokeAlpha="0.45"/>
    <!-- middle -->
    <path android:pathData="M 35,30 A 19,19 0 0,1 73,30"
          android:strokeColor="#A855F7"
          android:strokeWidth="1.8"
          android:strokeLineCap="round"
          android:fillColor="#00000000"
          android:strokeAlpha="0.70"/>
    <!-- inner (strongest) -->
    <path android:pathData="M 41,33 A 13,13 0 0,1 67,33"
          android:strokeColor="#A855F7"
          android:strokeWidth="2.2"
          android:strokeLineCap="round"
          android:fillColor="#00000000"
          android:strokeAlpha="0.95"/>

    <!-- Phone body: rounded rect 42x58 centered (36,38)→(78,96) -->
    <path android:pathData="M 36,38
                            h 36
                            a 8,8 0 0 1 8,8
                            v 42
                            a 8,8 0 0 1 -8,8
                            h -36
                            a 8,8 0 0 1 -8,-8
                            v -42
                            a 8,8 0 0 1 8,-8
                            z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="38"
                android:endX="54" android:endY="96"
                android:startColor="#1E1235"
                android:endColor="#0D0720"/>
        </aapt:attr>
    </path>
    <path android:pathData="M 36,38
                            h 36
                            a 8,8 0 0 1 8,8
                            v 42
                            a 8,8 0 0 1 -8,8
                            h -36
                            a 8,8 0 0 1 -8,-8
                            v -42
                            a 8,8 0 0 1 8,-8
                            z"
          android:strokeColor="#7C3AED"
          android:strokeWidth="0.9"
          android:fillColor="#00000000"/>

    <!-- Speaker slit -->
    <path android:pathData="M 49,42 h 10 a 0.8,0.8 0 0 1 0.8,0.8 v 0 a 0.8,0.8 0 0 1 -0.8,0.8 h -10 a 0.8,0.8 0 0 1 -0.8,-0.8 v 0 a 0.8,0.8 0 0 1 0.8,-0.8 z"
          android:fillColor="#2D1B4E"/>

    <!-- Screen recess -->
    <path android:pathData="M 33,46
                            h 42
                            a 3,3 0 0 1 3,3
                            v 36
                            a 3,3 0 0 1 -3,3
                            h -42
                            a 3,3 0 0 1 -3,-3
                            v -36
                            a 3,3 0 0 1 3,-3
                            z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54" android:centerY="67"
                android:gradientRadius="24"
                android:startColor="#2A1550"
                android:endColor="#0A0318"/>
        </aapt:attr>
    </path>

    <!-- Eye sclera on screen (ellipse approximated as very-flat rounded rect path) -->
    <path android:pathData="M 36,62
                            a 18,10 0 1 0 36,0
                            a 18,10 0 1 0 -36,0 z"
          android:fillColor="#080518"
          android:strokeColor="#7C3AED"
          android:strokeWidth="0.5"/>

    <!-- Iris -->
    <path android:pathData="M 46,62 a 8,8 0 1 0 16,0 a 8,8 0 1 0 -16,0 z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="53" android:centerY="60"
                android:gradientRadius="9"
                android:startColor="#A855F7"
                android:endColor="#3B0764"/>
        </aapt:attr>
    </path>

    <!-- Pupil -->
    <path android:pathData="M 50.5,62 a 3.5,3.5 0 1 0 7,0 a 3.5,3.5 0 1 0 -7,0 z"
          android:fillColor="#04020E"/>

    <!-- Crosshair inside pupil -->
    <path android:pathData="M 54,59.5 v 1.2 M 54,63.3 v 1.2 M 51.5,62 h 1.2 M 55.3,62 h 1.2"
          android:strokeColor="#E879F9"
          android:strokeWidth="0.55"
          android:strokeLineCap="round"
          android:fillColor="#00000000"/>

    <!-- Center highlight -->
    <path android:pathData="M 54,62 m -0.6,0 a 0.6,0.6 0 1 0 1.2,0 a 0.6,0.6 0 1 0 -1.2,0 z"
          android:fillColor="#F0ABFC"/>

    <!-- Home indicator -->
    <path android:pathData="M 47,90 h 14 a 0.9,0.9 0 0 1 0.9,0.9 v 0 a 0.9,0.9 0 0 1 -0.9,0.9 h -14 a 0.9,0.9 0 0 1 -0.9,-0.9 v 0 a 0.9,0.9 0 0 1 0.9,-0.9 z"
          android:fillColor="#4C1D95"
          android:fillAlpha="0.8"/>
</vector>
