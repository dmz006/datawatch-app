<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>en</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <!-- Version synced from gradle.properties via CI / build-ios-framework.sh -->
    <key>CFBundleShortVersionString</key>
    <string>$(MARKETING_VERSION)</string>
    <key>CFBundleVersion</key>
    <string>$(CURRENT_PROJECT_VERSION)</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>

    <!-- Push notifications: APNs background delivery -->
    <key>UIBackgroundModes</key>
    <array>
        <string>remote-notification</string>
    </array>

    <!-- Microphone: Whisper voice transcription -->
    <key>NSMicrophoneUsageDescription</key>
    <string>datawatch uses the microphone to record voice commands for transcription via your configured Whisper backend.</string>

    <!-- Biometrics: Face ID / Touch ID for token-protected profiles -->
    <key>NSFaceIDUsageDescription</key>
    <string>datawatch uses Face ID to protect access to your server profiles.</string>

    <!-- Local network: user-configured servers may be on the LAN -->
    <key>NSLocalNetworkUsageDescription</key>
    <string>datawatch connects to server addresses you configure, which may be on your local network.</string>

    <!--
      App Transport Security: the app supports user-configured servers that
      may use HTTP (not HTTPS) or self-signed TLS certificates. HTTP is
      explicitly warned about in the UI and is the user's deliberate choice.
    -->
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
</dict>
</plist>
